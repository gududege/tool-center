{
  "type": "VerticalLayout",
  "elements": [
    {
      "type": "Group",
      "label": "📁 Required Paths",
      "label_cn": "📁 必需路径",
      "elements": [
        {
          "type": "Control",
          "scope": "#/properties/indir",
          "options": {
            "folderPicker": true
          }
        },
        {
          "type": "Control",
          "scope": "#/properties/outdir",
          "options": {
            "folderPicker": true
          }
        }
      ]
    },
    {
      "type": "Group",
      "label": "⚙️ Export Settings",
      "label_cn": "⚙️ 导出设置",
      "elements": [
        {
          "type": "Control",
          "scope": "#/properties/exportMode"
        },
        {
          "type": "Control",
          "scope": "#/properties/keepFolderStructure"
        },
        {
          "type": "Control",
          "scope": "#/properties/maxWorkers"
        },
        {
          "type": "Control",
          "scope": "#/properties/projectFilter"
        }
      ]
    },
    {
      "type": "Group",
      "label": "📄 Block Format Options",
      "label_cn": "📄 块格式选项",
      "elements": [
        {
          "type": "Control",
          "scope": "#/properties/sclFormat"
        },
        {
          "type": "Control",
          "scope": "#/properties/stlFormat"
        },
        {
          "type": "Control",
          "scope": "#/properties/ladFormat"
        },
        {
          "type": "Control",
          "scope": "#/properties/dbFormat"
        }
      ]
    },
    {
      "type": "Group",
      "label": "📦 UDT & Safety Format Options",
      "label_cn": "📦 UDT 和安全格式选项",
      "elements": [
        {
          "type": "Control",
          "scope": "#/properties/udtFormat"
        },
        {
          "type": "Control",
          "scope": "#/properties/safetyDbFormat"
        },
        {
          "type": "Control",
          "scope": "#/properties/safetyUdtFormat"
        }
      ]
    },
    {
      "type": "Group",
      "label": "🔐 UMAC Authentication",
      "label_cn": "🔐 UMAC 认证",
      "elements": [
        {
          "type": "Control",
          "scope": "#/properties/umacUser"
        },
        {
          "type": "Control",
          "scope": "#/properties/umacPassword",
          "options": {
            "inputType": "password"
          }
        }
      ]
    },
    {
      "type": "Group",
      "label": "🛠️ Advanced",
      "label_cn": "🛠️ 高级",
      "elements": [
        {
          "type": "Control",
          "scope": "#/properties/portalMode"
        },
        {
          "type": "Control",
          "scope": "#/properties/loglevel"
        },
        {
          "type": "Control",
          "scope": "#/properties/logfile",
          "options": {
            "saveFilePicker": true
          }
        }
      ]
    }
  ]
}
