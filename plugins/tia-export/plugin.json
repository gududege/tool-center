{
  "$schema": "../../../../docs/plugin.schema.json",
  "schemaVersion": "1.0",
  "id": "tia-export",
  "name": "TIA Portal Export",
  "name_cn": "TIA Portal 导出",
  "description": "Export content from Siemens TIA Portal projects (V17-V20) using the official Openness API. Supports batch export of hardware, blocks, tag tables, UDTs, watch tables, and cross-references.",
  "description_cn": "使用官方 Openness API 从西门子 TIA Portal 项目 (V17-V20) 导出内容。支持批量导出硬件、块、变量表、UDT、监视表和交叉引用。",
  "version": "1.0.0",
  "author": "gududege",
  "homepage": "https://github.com/gududege/tia-exporter",
  "icon": "",
  "navigation": {
    "group": ["Industrial Automation", "TIA Portal"],
    "group_cn": ["工业自动化", "TIA Portal"],
    "order": 1
  },
  "form": {
    "schema": "schema.json",
    "uischema": "uischema.json"
  },
  "execution": {
    "exe": "tia-export.exe",
    "parameters": [
      {
        "field": "indir",
        "kind": "option",
        "flag": "--indir"
      },
      {
        "field": "outdir",
        "kind": "option",
        "flag": "--outdir"
      },
      {
        "field": "exportMode",
        "kind": "option",
        "flag": "--export-mode"
      },
      {
        "field": "keepFolderStructure",
        "kind": "switch",
        "flag": "--keep-folder-structure"
      },
      {
        "field": "maxWorkers",
        "kind": "option",
        "flag": "--max-workers"
      },
      {
        "field": "projectFilter",
        "kind": "option",
        "flag": "--project-filter"
      },
      {
        "field": "sclFormat",
        "kind": "option",
        "flag": "--scl-format"
      },
      {
        "field": "stlFormat",
        "kind": "option",
        "flag": "--stl-format"
      },
      {
        "field": "ladFormat",
        "kind": "option",
        "flag": "--lad-format"
      },
      {
        "field": "dbFormat",
        "kind": "option",
        "flag": "--db-format"
      },
      {
        "field": "udtFormat",
        "kind": "option",
        "flag": "--udt-format"
      },
      {
        "field": "safetyDbFormat",
        "kind": "option",
        "flag": "--safety-db-format"
      },
      {
        "field": "safetyUdtFormat",
        "kind": "option",
        "flag": "--safety-udt-format"
      },
      {
        "field": "umacUser",
        "kind": "option",
        "flag": "--umac-user"
      },
      {
        "field": "umacPassword",
        "kind": "option",
        "flag": "--umac-password"
      },
      {
        "field": "logfile",
        "kind": "option",
        "flag": "--logfile"
      },
      {
        "field": "loglevel",
        "kind": "option",
        "flag": "--loglevel"
      },
      {
        "field": "portalMode",
        "kind": "option",
        "flag": "--portal-mode"
      }
    ]
  },
  "output": {
    "type": "text"
  },
  "capabilities": [
    "file-input",
    "file-output"
  ]
}
