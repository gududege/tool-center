{
  "type": "VerticalLayout",
  "elements": [
    {
      "type": "Group",
      "label": "Target",
      "label_cn": "目标",
      "elements": [
        {
          "type": "Control",
          "scope": "#/properties/host"
        },
        {
          "type": "Control",
          "scope": "#/properties/port"
        }
      ]
    },
    {
      "type": "Group",
      "label": "Probe Settings",
      "label_cn": "探测设置",
      "elements": [
        {
          "type": "Control",
          "scope": "#/properties/interval"
        },
        {
          "type": "Control",
          "scope": "#/properties/timeout"
        },
        {
          "type": "Control",
          "scope": "#/properties/maxProbes"
        },
        {
          "type": "Control",
          "scope": "#/properties/retryResolve"
        }
      ]
    },
    {
      "type": "Group",
      "label": "Network Options",
      "label_cn": "网络选项",
      "elements": [
        {
          "type": "Control",
          "scope": "#/properties/ipv4Only"
        },
        {
          "type": "Control",
          "scope": "#/properties/ipv6Only"
        },
        {
          "type": "Control",
          "scope": "#/properties/sourceInterface"
        }
      ]
    },
    {
      "type": "Group",
      "label": "Display",
      "label_cn": "显示",
      "elements": [
        {
          "type": "Control",
          "scope": "#/properties/showTimestamp"
        },
        {
          "type": "Control",
          "scope": "#/properties/noColor"
        },
        {
          "type": "Control",
          "scope": "#/properties/showFailuresOnly"
        },
        {
          "type": "Control",
          "scope": "#/properties/showSourceAddress"
        }
      ]
    },
    {
      "type": "Group",
      "label": "Output Format",
      "label_cn": "输出格式",
      "elements": [
        {
          "type": "Control",
          "scope": "#/properties/jsonOutput"
        },
        {
          "type": "Control",
          "scope": "#/properties/prettyJson"
        },
        {
          "type": "Control",
          "scope": "#/properties/csvPath",
          "options": {
            "saveFilePicker": true
          }
        },
        {
          "type": "Control",
          "scope": "#/properties/dbPath",
          "options": {
            "saveFilePicker": true
          }
        }
      ]
    },
    {
      "type": "Group",
      "label": "Operation",
      "label_cn": "操作",
      "elements": [
        {
          "type": "Control",
          "scope": "#/properties/nonInteractive"
        }
      ]
    }
  ]
}
