{
  "$schema": "../../../docs/plugin.schema.json",
  "schemaVersion": "1.0",
  "id": "tcping",
  "name": "TCPING",
  "name_cn": "TCPING",
  "description": "A cross-platform TCP ping utility using TCP instead of ICMP. Monitor network latency, packet loss, and connection quality to a target host and port.",
  "description_cn": "跨平台的 TCP Ping 工具，使用 TCP 而非 ICMP。监控目标主机和端口的网络延迟、丢包率和连接质量。",
  "version": "2.8.0",
  "author": "pouriyajamshidi",
  "homepage": "https://github.com/pouriyajamshidi/tcping",
  "icon": "",
  "navigation": {
    "group": ["Network", "TCPING"],
    "group_cn": ["网络", "TCPING"],
    "order": 1
  },
  "form": {
    "schema": "schema.json",
    "uischema": "uischema.json"
  },
  "execution": {
    "exe": "tcping.exe",
    "parameters": [
      {
        "field": "host",
        "kind": "argument"
      },
      {
        "field": "port",
        "kind": "argument"
      },
      {
        "field": "ipv4Only",
        "kind": "switch",
        "flag": "-4"
      },
      {
        "field": "ipv6Only",
        "kind": "switch",
        "flag": "-6"
      },
      {
        "field": "interval",
        "kind": "option",
        "flag": "-i"
      },
      {
        "field": "timeout",
        "kind": "option",
        "flag": "-t"
      },
      {
        "field": "maxProbes",
        "kind": "option",
        "flag": "-c"
      },
      {
        "field": "retryResolve",
        "kind": "option",
        "flag": "-r"
      },
      {
        "field": "sourceInterface",
        "kind": "option",
        "flag": "-I"
      },
      {
        "field": "showTimestamp",
        "kind": "switch",
        "flag": "-D"
      },
      {
        "field": "noColor",
        "kind": "switch",
        "flag": "--no-color"
      },
      {
        "field": "showFailuresOnly",
        "kind": "switch",
        "flag": "--show-failures-only"
      },
      {
        "field": "showSourceAddress",
        "kind": "switch",
        "flag": "--show-source-address"
      },
      {
        "field": "jsonOutput",
        "kind": "switch",
        "flag": "-j"
      },
      {
        "field": "prettyJson",
        "kind": "switch",
        "flag": "--pretty"
      },
      {
        "field": "csvPath",
        "kind": "option",
        "flag": "--csv"
      },
      {
        "field": "dbPath",
        "kind": "option",
        "flag": "--db"
      },
      {
        "field": "nonInteractive",
        "kind": "switch",
        "flag": "--non-interactive"
      }
    ]
  },
  "output": {
    "type": "text"
  },
  "capabilities": [
    "network",
    "file-output"
  ]
}
