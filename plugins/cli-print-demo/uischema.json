{
  "type": "VerticalLayout",
  "elements": [
    {
      "type": "Group",
      "label": "String Widgets",
      "label_cn": "字符串控件",
      "elements": [
        { "type": "Control", "scope": "#/properties/textInput" },
        {
          "type": "Control",
          "scope": "#/properties/textArea",
          "options": { "widget": "textarea" }
        },
        { "type": "Control", "scope": "#/properties/password" },
        { "type": "Control", "scope": "#/properties/email" },
        { "type": "Control", "scope": "#/properties/url" },
        {
          "type": "Control",
          "scope": "#/properties/fileInput",
          "options": { "filePicker": true }
        }
      ]
    },
    {
      "type": "Group",
      "label": "Date & Time Widgets",
      "label_cn": "日期时间控件",
      "elements": [
        { "type": "Control", "scope": "#/properties/date" },
        { "type": "Control", "scope": "#/properties/dateTime" },
        { "type": "Control", "scope": "#/properties/time" },
        { "type": "Control", "scope": "#/properties/color" }
      ]
    },
    {
      "type": "Group",
      "label": "Numeric Widgets",
      "label_cn": "数字控件",
      "elements": [
        { "type": "Control", "scope": "#/properties/number" },
        { "type": "Control", "scope": "#/properties/integer" },
        {
          "type": "Control",
          "scope": "#/properties/rangeNum",
          "options": { "widget": "range" }
        }
      ]
    },
    {
      "type": "Group",
      "label": "Boolean Widgets",
      "label_cn": "布尔控件",
      "elements": [
        { "type": "Control", "scope": "#/properties/booleanCheck" },
        {
          "type": "Control",
          "scope": "#/properties/booleanRadio",
          "options": { "widget": "radio" }
        }
      ]
    },
    {
      "type": "Group",
      "label": "Enum / Select Widgets",
      "label_cn": "枚举/选择控件",
      "elements": [
        { "type": "Control", "scope": "#/properties/enumSelect" },
        {
          "type": "Control",
          "scope": "#/properties/enumRadio",
          "options": { "widget": "radio" }
        },
        { "type": "Control", "scope": "#/properties/singleSelect" }
      ]
    },
    {
      "type": "Group",
      "label": "Array Widgets",
      "label_cn": "数组控件",
      "elements": [
        { "type": "Control", "scope": "#/properties/arrayEnum" },
        {
          "type": "Control",
          "scope": "#/properties/arrayMulti",
          "options": { "widget": "select" }
        }
      ]
    },
    {
      "type": "Group",
      "label": "Other Widgets",
      "label_cn": "其他控件",
      "elements": [
        { "type": "Control", "scope": "#/properties/nestedName" },
        { "type": "Control", "scope": "#/properties/nestedAge" },
        {
          "type": "Control",
          "scope": "#/properties/hiddenField",
          "options": { "widget": "hidden" }
        }
      ]
    }
  ]
}
